@echo off
chcp 65001 >nul
echo ============================================================
echo 卸载TP-Link路由器账号清理服务
echo ============================================================
echo.

REM 停止服务
echo 正在停止服务...
sc stop TPLinkShutdownCleanup

timeout /t 3 >nul

REM 删除服务
echo 正在删除服务...
sc delete TPLinkShutdownCleanup

if %ERRORLEVEL% equ 0 (
    echo.
    echo ============================================================
    echo 服务卸载成功！
    echo ============================================================
) else (
    echo.
    echo ============================================================
    echo 服务卸载失败或服务不存在
    echo ============================================================
)

pause
